{
  "name": "iiro.fi",
  "version": "34.20.4",
  "private": true,
  "description": "A static site",
  "homepage": "https://codeberg.org/iiroj/iiro.fi",
  "license": "MIT",
  "author": "Iiro Jäppinen <iiro@jappinen.fi> (https://iiro.fi)",
  "repository": {
    "type": "git",
    "url": "https://codeberg.org/iiroj/iiro.fi.git"
  },
  "type": "module",
  "scripts": {
    "prepare": "husky",
    "start": "serve -p 3000 public",
    "fmt": "oxfmt check .",
    "lint": "oxlint check .",
    "build": "node --import tsx build.tsx",
    "version": "commit-and-tag-version --noBumpWhenEmptyChanges"
  },
  "devDependencies": {
    "@commitlint/cli": "21.0.1",
    "@commitlint/config-conventional": "21.0.1",
    "@types/node": "25.8.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "commit-and-tag-version": "12.7.3",
    "husky": "9.1.7",
    "lint-staged.sh": "0.6.0",
    "oxfmt": "0.49.0",
    "oxlint": "1.64.0",
    "oxlint-tsgolint": "0.22.1",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "serve": "14.2.6",
    "tsx": "4.22.0"
  },
  "devEngines": {
    "packageManager": {
      "name": "npm",
      "onFail": "error"
    },
    "runtime": {
      "name": "node",
      "onFail": "error"
    }
  }
}
