{
  "name": "iiro.fi",
  "version": "34.5.1",
  "description": "A static site",
  "author": "Iiro Jäppinen <iiro@jappinen.fi> (https://iiro.fi)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://codeberg.org/iiroj/iiro.fi.git"
  },
  "private": true,
  "type": "module",
  "devEngines": {
    "runtime": {
      "name": "bun",
      "onFail": "error"
    },
    "packageManager": {
      "name": "bun",
      "onFail": "error"
    }
  },
  "scripts": {
    "prepare": "husky",
    "start": "bun --watch run dev.tsx",
    "lint": "biome check",
    "bundle": "bun run bundle.tsx",
    "version": "commit-and-tag-version"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.13",
    "@commitlint/cli": "20.4.0",
    "@commitlint/config-conventional": "20.4.0",
    "@types/bun": "1.3.8",
    "@types/react": "19.2.10",
    "@types/react-dom": "19.2.3",
    "commit-and-tag-version": "12.6.1",
    "husky": "9.1.7",
    "prettier": "3.8.1",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  }
}
