{
  "name": "iiro.fi",
  "version": "34.19.0",
  "private": true,
  "description": "A static site",
  "homepage": "https://codeberg.org/iiroj/iiro.fi",
  "license": "MIT",
  "author": "Iiro Jäppinen <iiro@jappinen.fi> (https://iiro.fi)",
  "repository": {
    "type": "git",
    "url": "https://codeberg.org/iiroj/iiro.fi.git"
  },
  "type": "module",
  "scripts": {
    "prepare": "husky",
    "start": "bun --watch dev.tsx",
    "fmt": "oxfmt check .",
    "lint": "oxlint check .",
    "build": "bun build.tsx",
    "version": "commit-and-tag-version --noBumpWhenEmptyChanges"
  },
  "devDependencies": {
    "@commitlint/cli": "20.5.3",
    "@commitlint/config-conventional": "20.5.3",
    "@types/bun": "1.3.13",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "commit-and-tag-version": "12.7.1",
    "husky": "9.1.7",
    "lint-staged.sh": "0.6.0",
    "oxfmt": "0.47.0",
    "oxlint": "1.62.0",
    "oxlint-tsgolint": "0.22.1",
    "react": "19.2.5",
    "react-dom": "19.2.5"
  },
  "devEngines": {
    "packageManager": {
      "name": "bun",
      "onFail": "error"
    },
    "runtime": {
      "name": "bun",
      "onFail": "error"
    }
  }
}
