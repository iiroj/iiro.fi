{
  "name": "iiro.fi",
  "version": "34.10.1",
  "description": "A static site",
  "author": "Iiro Jäppinen <iiro@jappinen.fi> (https://iiro.fi)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://codeberg.org/iiroj/iiro.fi.git"
  },
  "private": true,
  "type": "module",
  "devEngines": {
    "runtime": {
      "name": "bun",
      "onFail": "error"
    },
    "packageManager": {
      "name": "bun",
      "onFail": "error"
    }
  },
  "scripts": {
    "prepare": "husky",
    "start": "bun --watch run dev.tsx",
    "lint": "biome check",
    "build": "bun run build.tsx",
    "version": "commit-and-tag-version",
    "deploy": "tofu -chdir=infra apply"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.6",
    "@commitlint/cli": "20.4.3",
    "@commitlint/config-conventional": "20.4.3",
    "@types/bun": "1.3.10",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@typescript/native-preview": "7.0.0-dev.20260307.1",
    "commit-and-tag-version": "12.6.1",
    "husky": "9.1.7",
    "lint-staged.sh": "0.1.2",
    "prettier": "3.8.1",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  }
}
