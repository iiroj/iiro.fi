{
  "name": "iiro.fi",
  "version": "34.21.0",
  "private": true,
  "description": "A static site",
  "homepage": "https://codeberg.org/iiroj/iiro.fi",
  "license": "MIT",
  "author": "Iiro Jäppinen <iiro@jappinen.fi> (https://iiro.fi)",
  "repository": {
    "type": "git",
    "url": "https://codeberg.org/iiroj/iiro.fi.git"
  },
  "type": "module",
  "scripts": {
    "prepare": "husky",
    "start": "node --import tsx --watch build.tsx",
    "fmt": "oxfmt check .",
    "lint": "oxlint check .",
    "build": "node --import tsx build.tsx",
    "version": "commit-and-tag-version --noBumpWhenEmptyChanges"
  },
  "devDependencies": {
    "@commitlint/cli": "21.0.2",
    "@commitlint/config-conventional": "21.0.2",
    "@types/node": "26.0.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@types/serve-handler": "6.1.4",
    "commit-and-tag-version": "12.7.3",
    "husky": "9.1.7",
    "lint-staged.sh": "0.6.9",
    "oxfmt": "0.55.0",
    "oxlint": "1.70.0",
    "oxlint-tsgolint": "0.23.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "serve-handler": "6.1.7",
    "tinyexec": "1.2.4",
    "tsx": "4.22.4"
  },
  "devEngines": {
    "packageManager": {
      "name": "npm",
      "onFail": "error"
    },
    "runtime": {
      "name": "node",
      "onFail": "error"
    }
  }
}
